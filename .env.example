# Shopify app credentials, from your Partner Dashboard > Apps > this app > Client credentials
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_products,write_products

# Public URL of this app once deployed (e.g. https://bulk-price-editor-web.onrender.com)
SHOPIFY_APP_URL=

# MySQL connection string for your serveriai.lt database
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://user:password@host:3306/bulk_price_editor"
